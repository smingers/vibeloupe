{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/plugins/pm-skills/scripts/sync-log-pull.js\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/plugins/pm-skills/scripts/sync-log-push.js\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
